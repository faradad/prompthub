---
import BaseLayout from '../layouts/BaseLayout.astro';
import PromptCard from '../components/PromptCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const prompts = await getCollection('prompts');
  const categories = [...new Set(prompts.map(p => p.data.category))];
  return categories.map(cat => ({ params: { category: cat } }));
}

const { category } = Astro.params;

const allPrompts = await getCollection('prompts');
const categoryPrompts = allPrompts
  .filter(p => p.data.category === category)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Collect all tags from this category for filtering
const allTags = [...new Set(categoryPrompts.flatMap(p => p.data.tags))];
---

<BaseLayout
  title={`${category}提示词`}
  description={`收集了${categoryPrompts.length}个${category}相关的AI提示词，涵盖${allTags.slice(0, 5).join('、')}等场景`}
>
  <!-- Breadcrumb -->
  <nav class="text-sm text-muted mb-6">
    <a href="/" class="hover:text-primary no-underline">首页</a>
    <span class="mx-2">/</span>
    <span class="text-text font-medium">{category}</span>
  </nav>

  <h1 class="text-3xl font-bold">{category}提示词</h1>
  <p class="mt-2 text-muted">
    共 {categoryPrompts.length} 个提示词，涵盖 {allTags.join('、')} 等场景
  </p>

  <!-- Tag filter -->
  <div id="tag-filters" class="flex flex-wrap gap-2 mt-6">
    <button
      data-tag=""
      class="tag-btn px-3 py-1 rounded-full text-sm border border-border
             bg-primary text-white transition-colors"
    >
      全部
    </button>
    {allTags.map(tag => (
      <button
        data-tag={tag}
        class="tag-btn px-3 py-1 rounded-full text-sm bg-card border border-border
               hover:border-primary hover:text-primary transition-colors"
      >
        {tag}
      </button>
    ))}
  </div>

  <!-- Prompt list -->
  <div id="prompt-list" class="mt-8 space-y-4">
    {categoryPrompts.length === 0 ? (
      <div class="text-center py-20 text-muted">
        <p class="text-lg">该分类暂无提示词</p>
        <p class="text-sm mt-2">我们会持续更新，敬请关注</p>
      </div>
    ) : (
      categoryPrompts.map(prompt => (
        <div data-tags={JSON.stringify(prompt.data.tags)}>
          <PromptCard prompt={prompt} />
        </div>
      ))
    )}
  </div>

  <script>
    const tagBtns = document.querySelectorAll('#tag-filters .tag-btn');
    const items = document.querySelectorAll('#prompt-list [data-tags]');

    function filterByTag(tag: string) {
      tagBtns.forEach(btn => {
        const isActive = btn.getAttribute('data-tag') === tag;
        btn.className = isActive
          ? btn.className.replace(/bg-card border-border/, 'bg-primary text-white').replace(/hover:[^\s]+/g, '')
          : btn.className.replace(/bg-primary text-white/, 'bg-card border-border hover:border-primary hover:text-primary');
      });
      items.forEach(el => {
        const tags: string[] = JSON.parse(el.getAttribute('data-tags') || '[]');
        (el as HTMLElement).style.display = !tag || tags.includes(tag) ? '' : 'none';
      });
    }

    tagBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const tag = btn.getAttribute('data-tag') || '';
        history.replaceState(null, '', tag ? `?tag=${tag}` : window.location.pathname);
        filterByTag(tag);
      });
    });

    // Apply initial filter from URL
    const params = new URLSearchParams(window.location.search);
    const activeTag = params.get('tag') || '';
    filterByTag(activeTag);
  </script>
</BaseLayout>
